# ── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__USER=bacteria
POSTGRES__PASSWORD=bacteria
POSTGRES__DB=bacteria

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER__CONCURRENCY=5
WORKER__POLL_INTERVAL=5
WORKER__STUCK_THRESHOLD=600

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT__MODEL=claude-sonnet-4-6
AGENT__MAX_TURNS=20
AGENT__MAX_COST=1.0

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP__WEBHOOK_SECRET=dev-secret
